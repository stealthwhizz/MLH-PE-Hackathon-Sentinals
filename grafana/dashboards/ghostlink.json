{
  "id": null,
  "uid": "ghostlink-overview",
  "title": "GhostLink Command Center",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Canary checks per second",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "ghostlink-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(ghostlink_canary_success_total{job=\"ghostlink-security\"}[5m])) or vector(0)",
          "legendFormat": "canary checks/s"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 2,
      "title": "Canary latency (avg/max)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "ghostlink-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg(ghostlink_canary_latency_seconds{job=\"ghostlink-security\"})",
          "legendFormat": "avg latency"
        },
        {
          "refId": "B",
          "expr": "max(ghostlink_canary_latency_seconds{job=\"ghostlink-security\"})",
          "legendFormat": "max latency"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "id": 3,
      "title": "Error rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "ghostlink-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(ghostlink_canary_failures_total{job=\"ghostlink-security\"}[5m])) or vector(0)",
          "legendFormat": "canary failures/s"
        },
        {
          "refId": "B",
          "expr": "sum(rate(ghostlink_blocked_requests_total{job=\"ghostlink-security\"}[5m])) or vector(0)",
          "legendFormat": "blocked requests/s"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 4,
      "title": "Ghost traffic",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "ghostlink-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(ghost_probes_total[1m])) or vector(0)",
          "legendFormat": "inactive URL probes/s"
        },
        {
          "refId": "B",
          "expr": "sum(rate(ghostlink_invalid_short_code_hits_total{job=\"ghostlink-security\"}[5m])) or vector(0)",
          "legendFormat": "invalid short-code hits/s"
        },
        {
          "refId": "C",
          "expr": "sum(rate(ghostlink_repeated_user_agent_hits_total{job=\"ghostlink-security\"}[5m])) or vector(0)",
          "legendFormat": "repeat UA hits/s"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "id": 5,
      "title": "Link health distribution",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "ghostlink-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "lineInterpolation": "linear",
            "barAlignment": 0,
            "lineWidth": 1,
            "fillOpacity": 60,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never",
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "ghostlink_safe_links_total{job=\"ghostlink-security\"}",
          "legendFormat": "SAFE"
        },
        {
          "refId": "B",
          "expr": "ghostlink_watchlist_links_total{job=\"ghostlink-security\"}",
          "legendFormat": "WATCHLIST"
        },
        {
          "refId": "C",
          "expr": "ghostlink_threat_links_total{job=\"ghostlink-security\"}",
          "legendFormat": "THREAT"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 6,
      "title": "Suspicious clients",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "ghostlink-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "ghostlink_suspicious_clients_total{job=\"ghostlink-security\"}",
          "legendFormat": "suspicious clients"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
    {
      "id": 7,
      "title": "Feature flags status",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "ghostlink-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by(flag) (ghostlink_feature_flag_enabled)",
          "format": "table",
          "instant": true,
          "legendFormat": "feature flags"
        }
      ],
      "options": {
        "showHeader": true,
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "countRows": false,
          "fields": ""
        }
      }
    },
    {
      "id": 8,
      "title": "Release footprint by version",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "ghostlink-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by(version) (ghostlink_release_info)",
          "legendFormat": "{{version}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 9,
      "title": "App instance health",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "ghostlink-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=\"ghostlink-backends\",instance=\"app1:5000\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "app1"
        },
        {
          "refId": "B",
          "expr": "up{job=\"ghostlink-backends\",instance=\"app2:5000\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "app2"
        }
      ],
      "options": {
        "showHeader": true,
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "countRows": false,
          "fields": ""
        }
      }
    },
    {
      "id": 10,
      "title": "Canary success ratio",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "ghostlink-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "clamp_max(sum(increase(ghostlink_canary_success_total{job=\"ghostlink-security\"}[5m])) / clamp_min(sum(increase(ghostlink_canary_success_total{job=\"ghostlink-security\"}[5m])) + sum(increase(ghostlink_canary_failures_total{job=\"ghostlink-security\"}[5m])), 1), 1)",
          "legendFormat": "success ratio (5m)"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
    {
      "id": 11,
      "title": "Quarantine rate",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "ghostlink-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(ghostlink_quarantined_urls_total{job=\"ghostlink-security\"}) / clamp_min(max(urls_active_total), 1)",
          "legendFormat": "quarantine ratio"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
    {
      "id": 12,
      "title": "Blocked requests",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "ghostlink-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(ghostlink_blocked_requests_total{job=\"ghostlink-security\"}[1m])) or vector(0)",
          "legendFormat": "blocked requests/s"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "templating": {
    "list": []
  },
  "tags": [
    "ghostlink",
    "command-center"
  ],
  "editable": true,
  "graphTooltip": 0,
  "links": []
}
