  "panels": [
    {
      "id": 13,
      "title": "Mission Brief",
      "type": "text",
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "content": "# GhostLink Pulse Deck\nSecurity command center for short-link protection, release confidence, and edge resilience.\n**Live profile:** refresh every 5s | window last 1h | sources ghostlink-security + ghostlink-backends | read flow KPI -> anomaly lanes -> ops state.",
        "mode": "markdown"
      }
    },
    {
      "id": 10,
      "title": "Canary success ratio (5m)",
      "description": "Immediate confidence signal for canary health.",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "ghostlink-prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.95
              },
              {
                "color": "green",
                "value": 0.99
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "clamp_max(sum(increase(ghostlink_canary_success_total{job=\"ghostlink-security\"}[5m])) / clamp_min(sum(increase(ghostlink_canary_success_total{job=\"ghostlink-security\"}[5m])) + sum(increase(ghostlink_canary_failures_total{job=\"ghostlink-security\"}[5m])), 1), 1)",
          "legendFormat": "success ratio (5m)"
        }
      ],
      "options": {
        "colorMode": "background_solid",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
